# Gateway (Rust) — copy to .env in gateway/

APP_ENV=dev
PORT=9115

DATABASE_URL=postgresql://postgres:password@localhost:5432/optrouter
REDIS_URL=redis://127.0.0.1:6379

# Provider keys (at least one for real upstream calls)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Optional overrides
# OPENAI_BASE_URL=https://api.openai.com/v1
# KEY_CACHE_TTL_SECS=300
# PROVIDER_TIMEOUT_SECS=120
# Provider / 本机 /health 自检失败时是否退出（默认 false，仅 warn）
# GATEWAY_STARTUP_CHECK_EXIT_ON_FAIL=false
# 仍失败时请确认本机 Redis 已启动（/health 依赖 Redis PING）

# Prometheus 文本指标：GET http://localhost:9115/metrics

# HTTP 代理（仅当 PROXY_ENABLED=true 时生效；false 时禁用系统/环境变量代理）
# PROXY_ENABLED=false
# PROXY_URL=http://127.0.0.1:7890
