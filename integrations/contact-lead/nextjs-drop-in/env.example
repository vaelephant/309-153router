# 线索服务（必填，否则 /api/lead 返回 500）
LEAD_API_BASE_URL=https://your-lead-api.example.com
LEAD_API_KEY=your_bearer_token
# 二选一：项目 slug 或项目名（与线索服务约定一致）
LEAD_PROJECT_SLUG=your-project-slug
# LEAD_PROJECT_NAME=Your Project Name

# 联系表单专用钉钉（与注册/登录播报分开，可进不同群）
# DINGTALK_CONTACT_ENABLED=true
# DINGTALK_CONTACT_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=...
# DINGTALK_CONTACT_SECRET=
